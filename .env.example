# 이메일 발송 설정 (Gmail SMTP 기준)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# JWT 서명 키 (256비트 이상의 랜덤 문자열)
JWT_SECRET=

# AWS S3 / CloudFront 설정
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_CLOUDFRONT_DOMAIN=

# 카카오 도서 API (https://developers.kakao.com)
KAKAO_REST_API_KEY=
